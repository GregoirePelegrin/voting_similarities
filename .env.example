# Backend configuration — copy to .env and customize
# The backend reads these via pydantic-settings

DATABASE_URL=sqlite+aiosqlite:///data/dev.db
API_PORT=8000
API_HOST=0.0.0.0
RELOAD=True
CORS_ORIGINS=["*"]
DB_ECHO=False
DB_POOL_SIZE=5
UVICORN_WORKERS=1
LOG_LEVEL=INFO
SIMILARITY_W_YES=1.0
SIMILARITY_W_NO=0.2
SIMILARITY_W_MISMATCH=0.5
SIMILARITY_SHRINKAGE_M=10
