# Production configuration — used by deploy.sh
# Connects to parliament_analysis_postgres container

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/voting_similarities
API_PORT=8000
API_HOST=0.0.0.0
RELOAD=False
CORS_ORIGINS=["*"]
DB_ECHO=False
DB_POOL_SIZE=10
UVICORN_WORKERS=4
LOG_LEVEL=INFO
SIMILARITY_W_YES=1.0
SIMILARITY_W_NO=0.2
SIMILARITY_W_MISMATCH=0.5
SIMILARITY_SHRINKAGE_M=10
