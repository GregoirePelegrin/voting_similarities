## Step 4: Frontend — multi-select filter

### File: `frontend/src/stores/ui-store.ts`

```typescript
class UiStore {
  selectedCategories: number[] = [];

  setCategories(ids: number[]) {
    if (ids.length > 3) return;  // enforce max 3
    this.selectedCategories = ids;
  }

  get categoriesKey(): string | null {
    if (this.selectedCategories.length === 0) return null;
    return [...this.selectedCategories].sort((a, b) => a - b).join("_");
  }
}
```

Remove `selectedCategory` and `setCategory()`.

### File: `frontend/src/components/shared/category-filter.tsx`

Replace `<Select>` with `<Autocomplete>` from MUI:

```tsx
import {Autocomplete, Chip, TextField} from "@mui/material";

const CategoryFilter: React.FC = observer(() => {
  const {categoriesStore, uiStore} = rootStore;
  const options = categoriesStore.categories.slice().sort((a, b) => a.name.localeCompare(b.name));

  return (
    <Autocomplete
      multiple
      size="small"
      sx={{minWidth: 300, maxWidth: 500}}
      options={options}
      value={options.filter(c => uiStore.selectedCategories.includes(c.id))}
      limitTags={3}
      disableCloseOnSelect
      onChange={(_, selected) => {
        uiStore.setCategories(selected.map(c => c.id));
      }}
      getOptionLabel={(c) => c.name}
      isOptionEqualToValue={(a, b) => a.id === b.id}
      renderInput={(params) => (
        <TextField {...params} label={CATEGORY_FILTER.LABEL} placeholder={CATEGORY_FILTER.ALL} />
      )}
      renderTags={(tagValue, getTagProps) =>
        tagValue.map((option, index) => (
          <Chip {...getTagProps({index})} key={option.id} label={option.name} size="small" />
        ))
      }
    />
  );
});
```

